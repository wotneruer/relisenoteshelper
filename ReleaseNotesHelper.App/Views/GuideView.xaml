<UserControl x:Class="ReleaseNotesHelper.App.Views.GuideView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- RNH_GUIDE_SUBTABS_CLEANUP_006_2026_06_19: guide is organized by inner tabs. No runtime logic. -->
    <UserControl.Resources>
        <Style x:Key="PageTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextMuted}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0 0 0 14"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0 0 0 14"/>
        </Style>

        <Style x:Key="AccentCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
        </Style>

        <Style x:Key="WarningCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="Margin" Value="0 0 0 8"/>
        </Style>

        <Style x:Key="SubTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="Margin" Value="0 8 0 4"/>
        </Style>

        <Style x:Key="BodyTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0 3 0 3"/>
            <Setter Property="LineHeight" Value="19"/>
        </Style>

        <Style x:Key="CodeTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0 3 0 3"/>
        </Style>


        <Style x:Key="GuideMutedStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextMuted}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="18"/>
            <Setter Property="Margin" Value="0 2 0 2"/>
        </Style>

        <Style x:Key="GuideSmallTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>

        <Style x:Key="GuidePillStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource RnhBrushInputBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Margin" Value="0 0 8 8"/>
        </Style>

        <Style x:Key="GuideTableHeaderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPanelElevated}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorder}"/>
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Setter Property="Padding" Value="10 8"/>
        </Style>

        <Style x:Key="GuideTableCellStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Setter Property="Padding" Value="10 8"/>
        </Style>

        <Style x:Key="GuideTableHeaderTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="GuideTableTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>

        <Style x:Key="GuideTableCodeStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="GuideTabStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Довідка Release Notes Helper"
                       Style="{StaticResource PageTitleStyle}"/>
        </StackPanel>

        <TabControl Grid.Row="1"
                    Style="{StaticResource GuideTabStyle}" Background="{StaticResource RnhBrushAppBackground}">
                        <TabItem Header="Основний flow">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Призначення"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Єдиний порядок підготовки release notes: від baseline і target refs до snapshot, AI notes та перевірки результатів." Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Порядок роботи"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="№" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Етап" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Результат" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="1" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Конфігурація" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Задані Git-доступ, папки репозиторіїв, output/logs і AI-режим." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="2" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Довідник сервісів" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Перевірені Git URL, активність сервісів, tags і branches." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="3" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Релізи" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="2" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Імпортований baseline зі складу інсталятора." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="4" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Шаблон релізу" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="4" Grid.Column="2" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Вибрані сервіси, baseline, default target і target refs." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="5" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="5" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Scan" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="5" Grid.Column="2" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Створений snapshot зі scope, commits, files і warnings." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="6" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="6" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="AI notes" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="6" Grid.Column="2" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Згенерований або fallback release notes на основі поточного snapshot." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="7" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="7" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="7" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Output" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="7" Grid.Column="2" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Перевірені metadata, scope-summary, prompt і client-release-notes." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Контрольні точки"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Що перевірити" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Очікуваний стан" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Baseline" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Попередній реліз містить коректні image tags, refs і SHA по сервісах." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Target refs" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Для кожного включеного сервісу вказано актуальний branch/tag/ref." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Warnings" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Попередження scan перевірені до запуску AI notes." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Snapshot" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="AI generation бере останній snapshot поточного шаблону, а не стару папку з такою самою назвою релізу." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

                        <TabItem Header="Релізи">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Призначення"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Імпорт і збереження baseline-релізів, з якими потім порівнюються target refs у шаблонах релізів." Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Основні дії"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Дія" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Результат" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Імпортувати baseline" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Утиліта читає installer yaml/yml і витягує сервіси, image tags, refs та SHA." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Перевірити таблицю сервісів" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Видно, які сервіси знайдені, які мають Git scope, а які потребують довідника сервісів." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Зберегти реліз" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Baseline стає доступним для шаблонів релізів і scan." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Створити відсутні сервіси" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Нові сервіси можна перенести у довідник для подальшого налаштування Git URL." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Використовувати коли"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Ситуація" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Що робити" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Починається новий реліз" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Спочатку імпортувати попередній installer baseline." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Змінився склад інсталятора" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Повторно імпортувати baseline і перевірити сервісну таблицю." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="У scan немає previous SHA" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Перевірити, чи потрібний сервіс присутній у baseline-релізі." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

                        <TabItem Header="Шаблони релізів">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Призначення"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Налаштування майбутнього релізу: склад сервісів, baseline, target refs, scan і запуск AI release notes." Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Основні дії"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Дія" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Результат" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Створити або відкрити шаблон" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Завантажуються назва релізу, default target, перелік сервісів і попередні target refs." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Включити сервіси" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="У scan потрапляють лише позначені сервіси." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Обрати target refs" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Для кожного сервісу задається branch/tag/ref, з яким порівнюється baseline." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Запустити Scan" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Формується snapshot зі scope змін." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Запустити AI notes" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="5" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="AI або fallback формує release notes на основі snapshot." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Open / Output" Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="6" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Відкривається папка або внутрішній перегляд результатів." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Ключові поля"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Поле" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource GuideTableHeaderStyle}"><TextBlock Text="Призначення" Style="{StaticResource GuideTableHeaderTextStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Назва шаблону" Style="{StaticResource GuideTableCodeStyle}"/></Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Внутрішня назва сценарію підготовки релізу." Style="{StaticResource GuideTableTextStyle}"/></Border>
                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource GuideTableCellStyle}"><TextBlock Text="Назва релізу" Style="{StaticResource GuideTableCodeStyle}"/></Border>
