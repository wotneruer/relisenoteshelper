<UserControl x:Class="ReleaseNotesHelper.App.Views.ReleaseTemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- RNH_UI_GUIDE_TAB_003_2026_06_19: compact work UI; full flow moved to separate Guide tab. Core scan/Git/AI logic is unchanged. -->
    <UserControl.Resources>
        <Style x:Key="CardBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0 0 0 12"/>
        </Style>

        <Style x:Key="SidebarCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="ActionBarStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextMuted}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextMuted}"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPrimary}"/>
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="DangerIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="CompactDataGridStyle" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="ColumnHeaderHeight" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="FlowBadgeStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
            <Setter Property="Foreground" Value="{StaticResource RnhBrushTextPrimary}"/>
            <Setter Property="Padding" Value="8 3"/>
            <Setter Property="Margin" Value="0 0 6 0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource SidebarCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <DockPanel Margin="0 0 0 12">
                        <TextBlock Text="Шаблони"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   DockPanel.Dock="Left"/>
                    </DockPanel>

                    <Button Content="+ Новий"
                            Style="{StaticResource BaseButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0 0 0 8"
                            ToolTip="Створити порожній шаблон."
                            Click="NewTemplate_Click" BorderThickness="1.5"/>

                    <Button Content="З baseline"
                            Style="{StaticResource BaseButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0 0 0 8"
                            ToolTip="Створити шаблон із сервісів останнього installer baseline."
                            Click="CreateFromBaseline_Click" BorderThickness="1.5"/>

                    <Button Content="З активних"
                            Style="{StaticResource BaseButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0 0 0 12"
                            ToolTip="Створити шаблон із сервісів, активних у довіднику."
                            Click="CreateFromActiveServices_Click" BorderThickness="1.5"/>

                    <TextBlock Text="Проект" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="TemplateProjectFilterComboBox"
                              MaxDropDownHeight="260"
                              IsTextSearchEnabled="True"
                              Margin="0 0 0 12"
                              MinHeight="34"
                              BorderThickness="1.5"
                              SelectionChanged="TemplateProjectFilterComboBox_SelectionChanged"/>

                    <TextBlock Text="Пошук" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="TemplateSearchTextBox"
                             Margin="0 0 0 12"
                             ToolTip="Пошук шаблону за назвою."
                             TextChanged="TemplateSearchTextBox_TextChanged" MinHeight="34" BorderThickness="1.5"/>
                </StackPanel>

                <ListBox Grid.Row="1"
                         x:Name="TemplatesListBox"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionChanged="TemplatesListBox_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource RnhBrushPanel}"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0 0 0 8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ProjectName}"
                                               Foreground="{StaticResource RnhBrushTextMuted}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Foreground="{StaticResource RnhBrushTextMuted}" FontSize="12">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} сервісів | {1}">
                                                <Binding Path="Services.Count"/>
                                                <Binding Path="DefaultTargetBranch"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0 0 0 10">
                <TextBlock Text="Шаблон релізу"
                           Style="{StaticResource PageTitleStyle}"
                           DockPanel.Dock="Left"/>
            </DockPanel>

            <Border Grid.Row="1" Style="{StaticResource ActionBarStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="SaveTemplateButton"
                                Content="Save"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Зберегти шаблон."
                                Click="SaveTemplate_Click" BorderThickness="1.5"/>

                        <Button x:Name="RunTemplateScopeButton"
                                Content="Scan"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Прогнати шаблон у потенційний реліз і створити snapshot."
                                Click="RunTemplateScope_Click" BorderThickness="1.5"/>

                        <Button x:Name="OpenAiRulesFolderButton"
                                Content="AI rules"
                                Style="{StaticResource BaseButtonStyle}"
                                ToolTip="Відкрити каталог кастомних правил AI для поточного проекту."
                                Click="OpenAiRulesFolder_Click" BorderThickness="1.5"/>

                        <Button x:Name="GenerateReleaseNotesButton"
                                Content="AI notes"
                                Style="{StaticResource BaseButtonStyle}"
                                ToolTip="Згенерувати release notes із останнього snapshot."
                                Click="GenerateReleaseNotes_Click" BorderThickness="1.5"/>

                        <Button x:Name="OpenReleaseFolderButton"
                                Content="Open"
                                Style="{StaticResource BaseButtonStyle}"
                                ToolTip="Відкрити output-папку останнього snapshot."
                                Click="OpenReleaseFolder_Click" BorderThickness="1.5"/>

                        <Button x:Name="DeleteTemplateButton"
                                Content="Delete"
                                Style="{StaticResource DangerButtonStyle}"
                                ToolTip="Видалити шаблон."
                                Click="DeleteTemplate_Click" BorderThickness="1.5"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 10">
                                <TextBlock Text="1. Основне"
                                           Style="{StaticResource SectionTitleStyle}"
                                           DockPanel.Dock="Left"/>
                            </DockPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Назва шаблону" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="TemplateNameTextBox"
                                             Margin="0 0 0 10"
                                             ToolTip="Імʼя шаблону. Якщо змінити і зберегти — шаблон перейменується, а не створить дубль." MinHeight="34" BorderThickness="1.5"/>

                                    <TextBlock Text="Проект" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="TemplateProjectTextBox"
                                             Margin="0 0 0 10"
                                             Text="RS.Core Poruch"
                                             ToolTip="Проект використовується для групування релізів і підключення кастомних AI правил." MinHeight="34" BorderThickness="1.5"/>

                                    <TextBlock Text="Опис" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="TemplateDescriptionTextBox"
                                             Height="66"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             ToolTip="Вільна нотатка до шаблону." BorderThickness="1.5"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Назва релізу" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="TemplateReleaseNameTextBox"
                                             Margin="0 0 0 10"
                                             Text="RS.Core {version}"
                                             ToolTip="Шаблон назви майбутнього релізу. {version} замінюється на версію." MinHeight="34" BorderThickness="1.5"/>

                                    <TextBlock Text="Default target" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="TemplateDefaultBranchTextBox"
                                             Text="origin/dev"
                                             ToolTip="Дефолтна гілка для сервісів без окремо заданого target refs." MinHeight="34" BorderThickness="1.5"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 10">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <TextBlock Text="2. Сервіси"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            DockPanel.Dock="Right"
                                            HorizontalAlignment="Right">
                                    <Button Content="Активні"
                                            Style="{StaticResource BaseButtonStyle}"
                                            Width="110"
                                            ToolTip="Включити всі активні сервіси з довідника."
                                            Click="IncludeActive_Click" BorderThickness="1.5"/>
                                    <Button Content="Всі"
                                            Style="{StaticResource BaseButtonStyle}"
                                            Width="76"
                                            ToolTip="Зняти включення з усіх сервісів."
                                            Click="ClearIncluded_Click" BorderThickness="1.5"/>
                                    <Button Content="Довідник"
                                            Style="{StaticResource BaseButtonStyle}"
                                            Width="118"
                                            Margin="0"
                                            ToolTip="Оновити рядки з довідника сервісів."
                                            Click="RefreshRowsFromCatalog_Click" BorderThickness="1.5"/>
                                </StackPanel>
                            </DockPanel>

                            <DataGrid x:Name="TemplateServicesDataGrid"
                                      Style="{StaticResource CompactDataGridStyle}"
                                      Height="300"
                                      IsReadOnly="False"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.IsDeferredScrollingEnabled="True">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="✓"
                                                            Binding="{Binding Included, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="42"/>
                                    <DataGridTextColumn Header="Сервіс"
                                                        Binding="{Binding ServiceName}"
                                                        IsReadOnly="True"
                                                        Width="170"/>
                                    <!-- RNH_STATUS_VISUALS_014_TEMPLATE_STATUS_COLUMN -->
                                    <DataGridTemplateColumn Header="Статус" Width="130" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}" BasedOn="{StaticResource RnhStatusChipBorderBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ValidationStatus}" Value="Valid">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushSuccessSoft}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushSuccess}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ValidationStatus}" Value="Needs Git URL">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushWarningSoft}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushWarning}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ValidationStatus}" Value="Unknown">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushInfoSoft}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushInfo}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ValidationStatus}" Value="External image">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushInfoSoft}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushInfo}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ValidationStatus}" Value="Ignore">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding ValidationStatus}" ToolTip="{Binding ValidationStatus}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource RnhStatusChipTextBaseStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ValidationStatus}" Value="Valid">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushSuccess}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ValidationStatus}" Value="Needs Git URL">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushWarning}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ValidationStatus}" Value="Unknown">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushInfo}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ValidationStatus}" Value="External image">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushInfo}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ValidationStatus}" Value="Ignore">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushTextMuted}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- RNH_TEMPLATE_BASE_REF_PER_SERVICE_026: editable per-service base ref for template comparison. -->
                                    <DataGridTemplateColumn Header="Base ref" Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding BaselineRef}"
                                                           ToolTip="{Binding BaselineRef}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox IsEditable="True"
                                                          MinHeight="26"
                                                          VerticalAlignment="Center"
                                                          IsTextSearchEnabled="False"
                                                          Text="{Binding BaselineRef, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          ItemsSource="{Binding TargetRefOptions}"
                                                          ToolTip="Початковий ref для порівняння цього сервісу: tag, branch або SHA. Використовується в режимі Baseline = Теги/SHA з шаблону." BorderThickness="1.5"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Base..." Width="68">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="..."
                                                        MinHeight="28"
                                                        Padding="8 0"
                                                        Margin="0"
                                                        VerticalAlignment="Center"
                                                        Click="PickBaseRef_Click"
                                                        ToolTip="Вибрати base ref для порівняння сервісу" BorderThickness="1.5"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- RNH_SERVICE_TARGET_REFS_V2_2026_06_19: editable per-service target refs. Multiple refs are separated by ; or ,. -->
                                    <DataGridTemplateColumn Header="Target refs" Width="240">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TargetBranch}"
                                                           ToolTip="{Binding TargetBranch}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox IsEditable="True"
                                                          MinHeight="26"
                                                          VerticalAlignment="Center"
                                                          IsTextSearchEnabled="False"
                                                          Text="{Binding TargetBranch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          ItemsSource="{Binding DataContext.TargetRefOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          ToolTip="Можна вписати вручну: origin/dev; origin/organizations" BorderThickness="1.5"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- RNH_TARGET_REFS_CHECKBOX_PICKER_2026_06_19: opens multi-select target refs dialog for the row service. -->
                                    <DataGridTemplateColumn Header="..." Width="58">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="..."
                                                        MinHeight="28"
                                                        Padding="8 0"
                                                        Margin="0"
                                                        VerticalAlignment="Center"
                                                        Click="PickTargetRefs_Click"
                                                        ToolTip="Вибрати target refs галочками" BorderThickness="1.5"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridCheckBoxColumn Header="Ask"
                                                            Binding="{Binding AskIfChanged, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="42"/>
                                    <DataGridTextColumn Header="Version"
                                                        Binding="{Binding BaselineVersion}"
                                                        IsReadOnly="True"
                                                        Width="88"/>
                                    <DataGridTextColumn Header="Git URL"
                                                        Binding="{Binding GitUrl}"
                                                        IsReadOnly="True"
                                                        Width="160"/>
                                    <DataGridTextColumn Header="Нотатка"
                                                        Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="160"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock x:Name="TemplateStatusTextBlock"
                                       Text="Очікування дії"
                                       Foreground="{StaticResource RnhBrushTextPrimary}"
                                       Margin="0 8 0 0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource RnhBrushPanel}"
                            CornerRadius="10"
                            Padding="14"
                            BorderBrush="{StaticResource RnhBrushBorderSubtle}"
                            BorderThickness="1"
                            Margin="0 0 0 12">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 10">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <TextBlock Text="3. Scan"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                </StackPanel>
                            </DockPanel>

                            <Grid Margin="0 0 0 12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Baseline" Style="{StaticResource FieldLabelStyle}"/>
                                    <Border Background="{StaticResource RnhBrushPanel}"
                                            BorderBrush="{StaticResource RnhBrushBorder}"
                                            BorderThickness="1.5"
                                            CornerRadius="6"
                                            MinHeight="34"
                                            Padding="10 7"
                                            ToolTip="Auto per service: Base ref → installer baseline SHA → previous release → baseline version.">
                                        <TextBlock Text="Auto per service"
                                                   Foreground="{StaticResource RnhBrushTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                    <ComboBox x:Name="ComparisonBaseComboBox"
                                              Visibility="Collapsed"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="Auto per service"/>
                                        <ComboBoxItem Content="Останній installer baseline"/>
                                        <ComboBoxItem Content="Попередній реліз цього шаблону"/>
                                        <ComboBoxItem Content="Теги/SHA з шаблону"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Visibility="Collapsed">
                                    <TextBlock Text="Diverged history" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="DivergedHistoryDiffModeComboBox"
                                              SelectedIndex="1">
                                        <ComboBoxItem Content="Strict previous..target"/>
                                        <ComboBoxItem Content="Auto: якщо diverged — merge-base..target"/>
                                        <ComboBoxItem Content="Завжди merge-base..target"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Версія" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="ReleaseVersionTextBox"
                                             Text="1.6.0"
                                             ToolTip="Версія нового релізу." MinHeight="34" BorderThickness="1.5"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Назва релізу" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="ReleaseNameTextBox"
                                             Text="RS.Core 1.6.0"
                                             ToolTip="Назва snapshot/release output." MinHeight="34" BorderThickness="1.5"/>
                                </StackPanel>
                            </Grid>

                            <!-- RNH_TARGET_REF_CONTROLS_2026_06_19: kept collapsed for compatibility with existing code-behind. Primary flow is per-service Target refs. -->
                            <StackPanel Margin="0 0 0 12" Visibility="Collapsed">
                                <TextBlock Text="Опційний override target ref на весь прогін" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid Margin="0 4 0 4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="RunTargetRefModeComboBox"
                                              Grid.Column="0"
                                              SelectedIndex="0" MinHeight="34" BorderThickness="1.5">
                                        <ComboBoxItem Content="З шаблону по сервісах"/>
                                        <ComboBoxItem Content="Один target ref для цього прогону"/>
                                    </ComboBox>

                                    <TextBox x:Name="RunTargetRefTextBox"
                                             Grid.Column="2"
                                             Text="origin/dev" MinHeight="34" BorderThickness="1.5"/>

                                    <Button x:Name="ApplyRunTargetToIncludedButton"
                                            Grid.Column="4"
                                            Content="Зафіксувати в включені"
                                            Style="{StaticResource BaseButtonStyle}"
                                            Click="ApplyRunTargetToIncluded_Click" BorderThickness="1.5"/>
                                </Grid>
                            </StackPanel>

                            <DockPanel Margin="0 0 0 8">
                                <TextBlock Text="Результат"
                                           FontWeight="SemiBold"
                                           DockPanel.Dock="Left"/>
                            </DockPanel>

                            <DataGrid x:Name="ScopeResultsDataGrid"
                                      Style="{StaticResource CompactDataGridStyle}"
                                      Height="230"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="✓"
                                                            Binding="{Binding Included}"
                                                            Width="42"/>
                                    <DataGridTextColumn Header="Сервіс"
                                                        Binding="{Binding ServiceName}"
                                                        Width="170"/>
                                    <!-- RNH_STATUS_VISUALS_014_SCOPE_STATUS_COLUMN -->
                                    <DataGridTemplateColumn Header="Статус" Width="120" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}" BasedOn="{StaticResource RnhStatusChipBorderBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Included">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushSuccessSoft}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushSuccess}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Changed">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushSuccessSoft}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushSuccess}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="No changes">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushPanel}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushBorderSubtle}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushInfoSoft}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushInfo}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                    <Setter Property="Background" Value="{StaticResource RnhBrushDangerSoft}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource RnhBrushDanger}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" ToolTip="{Binding Status}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource RnhStatusChipTextBaseStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Included">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushSuccess}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Changed">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushSuccess}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="No changes">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushTextMuted}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushTextMuted}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushTextMuted}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushInfo}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushDanger}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Комітів"
                                                        Binding="{Binding CommitCount}"
                                                        Width="68"/>
                                    <DataGridTextColumn Header="Файлів"
                                                        Binding="{Binding ChangedFilesCount}"
                                                        Width="62"/>
                                    <DataGridTextColumn Header="Target"
                                                        Binding="{Binding TargetRef}"
                                                        Width="150"/>
                                    <DataGridTextColumn Header="Diff"
                                                        Binding="{Binding DiffRange}"
                                                        Width="150"/>
                                    <!-- RNH_STATUS_VISUALS_014_WARNING_COLUMN -->
                                    <DataGridTemplateColumn Header="Warning" Width="230" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}" BasedOn="{StaticResource RnhStatusChipBorderBaseStyle}">
                                                            <Setter Property="MinWidth" Value="0"/>
                                                            <Setter Property="MaxWidth" Value="210"/>
                                                            <Setter Property="Background" Value="{StaticResource RnhBrushWarningSoft}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource RnhBrushWarning}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding GitHistoryWarning}" Value="">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding GitHistoryWarning}" Value="{x:Null}">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding GitHistoryWarning}" ToolTip="{Binding GitHistoryWarning}" TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource RnhStatusChipTextBaseStyle}">
                                                                <Setter Property="Foreground" Value="{StaticResource RnhBrushWarning}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding GitHistoryWarning}" Value="">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushTextMuted}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding GitHistoryWarning}" Value="{x:Null}">
                                                                        <Setter Property="Foreground" Value="{StaticResource RnhBrushTextMuted}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Prev SHA"
                                                        Binding="{Binding PreviousSha}"
                                                        Width="145"/>
                                    <DataGridTextColumn Header="Target SHA"
                                                        Binding="{Binding TargetSha}"
                                                        Width="145"/>
                                    <DataGridTextColumn Header="Нотатка"
                                                        Binding="{Binding ErrorMessage}"
                                                        Width="220"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock x:Name="ScopeStatusTextBlock"
                                       Text="Scan не виконано"
                                       Foreground="{StaticResource RnhBrushTextPrimary}"
                                       Margin="0 8 0 0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
