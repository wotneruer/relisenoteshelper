<UserControl x:Class="ReleaseNotesHelper.App.Views.ConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Margin="16">
        <StackPanel>


            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Background="{StaticResource RnhBrushPanel}"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0 0 0 16"
                            BorderBrush="{StaticResource RnhBrushBorderSubtle}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Git доступ"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0 0 0 12"/>

                            <TextBlock Text="Тип авторизації" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <ComboBox x:Name="GitAuthTypeComboBox"
                                      Margin="0 4 0 12" MinHeight="34" BorderThickness="1.5">
                                <ComboBoxItem Content="Personal Access Token / HTTPS" IsSelected="True"/>
                                <ComboBoxItem Content="SSH key"/>
                                <ComboBoxItem Content="Windows Credential Manager"/>
                            </ComboBox>

                            <TextBlock Text="Git username / email" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <TextBox x:Name="GitUsernameTextBox"
                                     Text="kirpichnikov_av"
                                     Margin="0 4 0 12" MinHeight="34" BorderThickness="1.5"/>

                            <TextBlock Text="Access token / password" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <PasswordBox x:Name="GitTokenPasswordBox"
                                         Margin="0 4 0 12" MinHeight="34" BorderThickness="1.5"/>

                            <TextBlock Text="Repository URL для перевірки" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <TextBox x:Name="TestRepositoryUrlTextBox"
                                     Text=""
                                     Margin="0 4 0 12" MinHeight="34" BorderThickness="1.5"/>

                            <CheckBox x:Name="StoreCredentialsCheckBox"
                                      Content="Зберігати токен у Windows Credential Manager"
                                      IsChecked="True"
                                      Margin="0 0 0 12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="Перевірити Git"
                                        Height="34"
                                        Click="CheckGitAccess_Click" BorderThickness="1.5"/>

                                <Button Grid.Column="2"
                                        Content="Перевірити repo"
                                        Height="34"
                                        Click="CheckRepositoryAccess_Click" BorderThickness="1.5"/>
                            </Grid>

                            <Border Background="{StaticResource RnhBrushPanel}"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0 14 0 0">
                                <StackPanel>
                                    <TextBlock Text="Статус перевірки"
                                               FontWeight="Bold"
                                               Margin="0 0 0 6"/>

                                    <TextBlock x:Name="GitStatusTextBlock"
                                               Text="Git: не перевірено"
                                               Foreground="{StaticResource RnhBrushTextMuted}"
                                               Margin="0 0 0 4"/>

                                    <TextBlock x:Name="RepositoryStatusTextBlock"
                                               Text="Repository: не перевірено"
                                               Foreground="{StaticResource RnhBrushTextMuted}"
                                               Margin="0 0 0 4"/>

                                    <TextBlock x:Name="LastGitCheckTextBlock"
                                               Text="Остання перевірка: —"
                                               Foreground="{StaticResource RnhBrushTextMuted}"
                                               FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource RnhBrushPanel}"
                            CornerRadius="10"
                            Padding="16"
                            BorderBrush="{StaticResource RnhBrushBorderSubtle}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Jira"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0 0 0 12"/>

                            <TextBlock Text="Jira base URL" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <TextBox x:Name="JiraBaseUrlTextBox"
                                     Text="https://your-company.atlassian.net"
                                     Margin="0 4 0 12" MinHeight="34" BorderThickness="1.5"/>

                            <TextBlock Text="Jira token" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <PasswordBox x:Name="JiraTokenPasswordBox"
                                         Margin="0 4 0 12" MinHeight="34" BorderThickness="1.5"/>

                            <CheckBox x:Name="LoadJiraTitlesCheckBox"
                                      Content="Підтягувати назви Jira-карток через API"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Background="{StaticResource RnhBrushPanel}"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0 0 0 16"
                            BorderBrush="{StaticResource RnhBrushBorderSubtle}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Робочі папки"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0 0 0 12"/>

                            <TextBlock Text="Папка для репозиторіїв" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <Grid Margin="0 4 0 12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="RepositoriesPathTextBox"
                                         Grid.Column="0"
                                         Text="" MinHeight="34" BorderThickness="1.5"/>

                                <Button Grid.Column="2"
                                        Content="Огляд..."
                                        Height="30"
                                        Click="BrowseRepositoriesPath_Click" BorderThickness="1.5"/>
                            </Grid>

                            <TextBlock Text="Папка для результатів" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <Grid Margin="0 4 0 12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="OutputPathTextBox"
                                         Grid.Column="0"
                                         Text="" MinHeight="34" BorderThickness="1.5"/>

                                <Button Grid.Column="2"
                                        Content="Огляд..."
                                        Height="30"
                                        Click="BrowseOutputPath_Click" BorderThickness="1.5"/>
                            </Grid>

                            <TextBlock Text="Папка для логів" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <Grid Margin="0 4 0 12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="LogsPathTextBox"
                                         Grid.Column="0"
                                         Text="" MinHeight="34" BorderThickness="1.5"/>

                                <Button Grid.Column="2"
                                        Content="Огляд..."
                                        Height="30"
                                        Click="BrowseLogsPath_Click" BorderThickness="1.5"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource RnhBrushPanel}"
                            CornerRadius="10"
                            Padding="16"
                            BorderBrush="{StaticResource RnhBrushBorderSubtle}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="AI генерація"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0 0 0 12"/>

                            <TextBlock Text="Режим AI" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <ComboBox x:Name="AiModeComboBox"
                                      Margin="0 4 0 12" MinHeight="34" BorderThickness="1.5">
                                <ComboBoxItem Content="Тільки сформувати prompt для копіювання" IsSelected="True"/>
                                <ComboBoxItem Content="OpenAI API"/>
                                <ComboBoxItem Content="Azure OpenAI"/>
                                <ComboBoxItem Content="Внутрішній AI endpoint"/>
                            </ComboBox>

                            <TextBlock Text="AI API key / token" Foreground="{StaticResource RnhBrushTextMuted}"/>
                            <PasswordBox x:Name="AiTokenPasswordBox"
                                         Margin="0 4 0 12" MinHeight="34" BorderThickness="1.5"/>

                            <CheckBox x:Name="HideTechnicalDataFromAiCheckBox"
                                      Content="Не передавати commit hash, авторів та службові дані в AI"
                                      IsChecked="True"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0 16 0 0">
                <Button Content="Зберегти конфігурацію"
                        Width="180"
                        Height="36"
                        Click="SaveConfiguration_Click" BorderThickness="1.5"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
